{
  "endpoint": "POST /init",
  "request": {
    "type": "object",
    "properties": {
      "token": { "type": "string" },
      "gameId": { "type": "string" },
      "currency": { "type": "string" }
    },
    "required": ["token", "gameId", "currency"]
  },
  "response": {
    "oneOf": [
      {
        "title": "InitResponse",
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "currency": { "type": "string" },
          "balance": { "type": "number" },
          "stakes": {
            "type": "array",
            "items": { "type": "number" }
          },
          "gameConfig": {
            "type": "object",
            "properties": {
              "reels": {
                "type": "object",
                "properties": {
                  "lengths": {
                    "type": "array",
                    "items": { "type": "number" }
                  },
                  "reelIndexes": {
                    "type": "array",
                    "items": {
                      "type": "array",
                      "items": { "type": "number" }
                    }
                  }
                },
                "required": ["lengths", "reelIndexes"]
              },
              "symbols": {
                "type": "array",
                "items": { "type": "string" }
              },
              "paytable": {
                "type": "object",
                "additionalProperties": { "type": "number" }
              },
              "winlines": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": "number" }
                }
              }
            },
            "required": ["reels", "symbols", "paytable", "winlines"]
          },
          "roundDetails": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "resolved": { "type": "boolean" },
                  "gameState": {
                    "type": "object",
                    "properties": {
                      "reelPositions": {
                        "type": "array",
                        "items": { "type": "number" }
                      },
                      "reelWindow": {
                        "type": "array",
                        "items": {
                          "type": "array",
                          "items": { "type": "string" }
                        }
                      },
                      "awards": {
                        "type": "array",
                        "items": {
                          "oneOf": [
                            {
                              "type": "object",
                              "properties": {
                                "name": { "type": "string", "enum": ["winlines"] },
                                "payout": { "type": "number" },
                                "lines": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "index": { "type": "number" },
                                      "winline": { "type": "array", "items": { "type": "number" } },
                                      "symbols": { "type": "array", "items": { "type": "string" } },
                                      "payout": { "type": "number" }
                                    },
                                    "required": ["index", "winline", "symbols", "payout"]
                                  }
                                }
                              },
                              "required": ["name", "payout", "lines"]
                            },
                            {
                              "type": "object",
                              "properties": {
                                "name": { "type": "string", "enum": ["fullHouseDouble"] },
                                "payout": { "type": "number" }
                              },
                              "required": ["name", "payout"]
                            }
                          ]
                        }
                      },
                      "totalWin": { "type": "number" }
                    },
                    "required": ["reelPositions", "reelWindow", "awards", "totalWin"]
                  },
                  "payout": {
                    "type": "object",
                    "properties": {
                      "stake": { "type": "number" },
                      "payout": { "type": "number" }
                    },
                    "required": ["stake", "payout"]
                  }
                },
                "required": ["resolved", "gameState", "payout"]
              },
              { "type": "null" }
            ]
          }
        },
        "required": ["sessionId", "currency", "balance", "stakes", "gameConfig", "roundDetails"]
      },
      { "$ref": "./error.json#/definitions/ErrorResponse" }
    ]
  }
}
